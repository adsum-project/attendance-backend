        {
          "name": "Get Course Modules",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}/modules?page=1&perPage=10"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Course modules returned', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('Assigned module in list', () => {",
                "  pm.expect(j.data).to.be.an('array');",
                "  const mod = j.data.find(m => m.moduleId === pm.collectionVariables.get('moduleId'));",
