    {
      "name": "5 - Timetable & Pagination",
      "item": [
        {
          "name": "Get Own Timetable",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/me?weekStart=2025-01-06"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "const roles = JSON.parse(pm.collectionVariables.get('authRoles') || '[]');",
                "const isDefaultOnly = roles.includes('default') && !roles.includes('admin') && !roles.includes('staff');",
                "if (isDefaultOnly) {",
                "  pm.test('Timetable returned', () => pm.response.to.have.status(200));",
                "  pm.test('Data is array', () => pm.expect(j.data).to.be.an('array'));",
                "} else {",
                "  pm.test('Timetable forbidden for non-default roles', () => pm.expect(pm.response.code).to.eql(403));",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Get Courses (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses?page=1&perPage=5&search=Postman"
          },
          "event": [{
