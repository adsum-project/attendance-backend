          "name": "Unassign Module from Course",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}/modules/{{moduleId}}"
          },
          "event": [{
            "listen": "test",
