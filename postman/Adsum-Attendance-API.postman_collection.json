          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}/modules"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Module no longer in list', () => {",
                "  const j = pm.response.json();",
                "  const mod = (j.data || []).find(m => m.moduleId === pm.collectionVariables.get('moduleId'));",
                "  pm.expect(mod).to.be.undefined;",
                "});"
              ],
              "type": "text/javascript"
            }
          }]
        }
      ]
