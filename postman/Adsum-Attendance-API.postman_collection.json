{
  "info": {
    "name": "Adsum Attendance API",
    "description": "Functional API tests. **Requires auth**: Copy session cookie from browser (e.g. cookie extension) into Postman before running. Tests create real data, verify responses, and clean up. Run collection in order.",
    "schema": "https://schema.postman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "courseId", "value": "" },
    { "key": "moduleId", "value": "" },
    { "key": "classId", "value": "" },
    { "key": "testCourseCode", "value": "9001" },
    { "key": "testModuleCode", "value": "PMT001" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.collectionVariables.get('runInitialized')) {",
          "  const r = () => Math.floor(Math.random() * 1000);",
          "  pm.collectionVariables.set('courseId', '');",
          "  pm.collectionVariables.set('moduleId', '');",
          "  pm.collectionVariables.set('classId', '');",
          "  pm.collectionVariables.set('testCourseCode', '9' + String(r()).padStart(3, '0'));",
          "  pm.collectionVariables.set('testModuleCode', 'PMT' + String(r()).padStart(3, '0'));",
          "  pm.collectionVariables.set('runInitialized', 'true');",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "0 - Prerequisites",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('API is up', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('Health response structure', () => {",
                "  pm.expect(j.success).to.be.true;",
                "  pm.expect(j.data).to.have.property('since');",
                "});"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Auth Me (verify session)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/auth/me"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "pm.test('Authenticated', () => pm.response.to.have.status(200));",
                "pm.test('User object present', () => {",
                "  pm.expect(j.success).to.be.true;",
                "  pm.expect(j.data.user).to.be.an('object');",
                "  pm.expect(j.data.user).to.have.property('id');",
                "});",
                "if (pm.response.code === 200) {",
                "  pm.collectionVariables.set('authUserId', j.data.user.id);",
                "  pm.collectionVariables.set('authRoles', JSON.stringify(j.data.user.roles || []));",
                "}",
                "if (pm.response.code !== 200) {",
                "  pm.collectionVariables.unset('runInitialized');",
                "  pm.execution.setNextRequest(null);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        }
      ]
    },
    {
      "name": "1 - Course CRUD",
      "item": [
        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseCode\": \"{{testCourseCode}}\",\n  \"courseName\": \"Postman Test Course\",\n  \"campus\": \"TestCampus\"\n}\n"
            },
            "url": "{{baseUrl}}/v1/timetable/courses"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const j = pm.response.json();",
                "pm.test('Course created', () => pm.response.to.have.status(201));",
                "pm.test('Returns courseId', () => {",
                "  pm.expect(j.data.courseId).to.be.a('string');",
                "  pm.expect(j.data.courseId.length).to.be.greaterThan(0);",
                "});",
                "if (pm.response.code === 201) {",
                "  pm.collectionVariables.set('courseId', j.data.courseId);",
                "} else {",
                "  pm.collectionVariables.unset('runInitialized');",
                "  pm.execution.setNextRequest(null);",
                "}"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Get Course",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Course retrieved', () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test('Course data matches created values', () => {",
                "  pm.expect(j.data.courseCode).to.eql(pm.collectionVariables.get('testCourseCode'));",
                "  pm.expect(j.data.courseName).to.eql('Postman Test Course');",
                "  pm.expect(j.data.campus).to.eql('TestCampus');",
                "});"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseName\": \"Postman Test Course Updated\",\n  \"campus\": \"UpdatedCampus\"\n}\n"
            },
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Course updated', () => pm.response.to.have.status(204));"
              ],
              "type": "text/javascript"
            }
          }]
        },
        {
          "name": "Get Course (verify update)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/v1/timetable/courses/{{courseId}}"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Updated values persisted', () => {",
                "  const j = pm.response.json();",
                "  pm.expect(j.data.courseName).to.eql('Postman Test Course Updated');",
                "  pm.expect(j.data.campus).to.eql('UpdatedCampus');",
                "});"
              ],
              "type": "text/javascript"
            }
          }]
        }
      ]
    },
